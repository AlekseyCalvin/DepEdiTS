{
  "name": "depedits",
  "version": "0.0.1",
  "description": "TypeScript port of DepEdit, the NLP tool for manipulating dependency trees and grammars",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "depedit-ts": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nlp",
    "typescript",
    "javascript",
    "syntax",
    "morphology",
    "universal-dependencies",
    "conllu",
    "depedit",
    "parser",
    "stanford",
    "ud"
  ],
  "author": "Aleksey Calvin Tsukanov, Amir Zeldes",
  "license": "apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/AlekseyCalvin/DepEdiTS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlekseyCalvin/DepEdiTS.git"
  },
  "bugs": {
    "url": "https://github.com/AlekseyCalvin/DepEdiTS/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}